@{
    Layout = null;
}

@model HelthTrack.Models.NutritionResult
@using Microsoft.AspNetCore.Http

@{
    var patientName = Context.Session.GetString("UserName") ?? "Patient";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Nutrition Result</title>

    <link rel="stylesheet" href="~/css/nutrition.css" />

    <style>
        .top-bar {
            padding: 16px 22px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 20px;
        }

        .logout {
            padding: 6px 12px;
            font-size: 14px;
            border-radius: 6px;
            text-decoration: none;
            background: rgba(0,0,0,0.15);
            color: #333;
            font-weight: 600;
        }

            .logout:hover {
                background: rgba(0,0,0,0.25);
            }

        .result-box {
            border: 1px solid #ddd;
            padding: 18px;
            border-radius: 10px;
            margin: 20px 0;
            text-align: center;
        }

        .result-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 12px;
            margin-top: 10px;
            border-radius: 8px;
            border: 1px solid #e0e0e0;
            font-weight: 600;
        }

        .buttons {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-top: 20px;
        }

        .btn-ht {
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
            color: #333;
            border: 1px solid #ccc;
            background: transparent;
            transition: background 0.2s ease;
        }

            .btn-ht:hover {
                background: rgba(0,0,0,0.05);
            }

        .back {
            display: inline-block;
            margin-top: 25px;
            color: #333;
            font-weight: bold;
            text-decoration: none;
        }
    </style>
</head>

<body>

    <div class="top-bar">
        <div>🥗 Nutrition Clinic</div>
        <a href="/Account/Logout" class="logout">Logout</a>
    </div>

    <div class="nutrition-container">
        <h2>Hello, @patientName</h2>
        <p>Your nutrition results are calculated below.</p>

        <div class="result-box">
            <h4 class="result-title">Results</h4>

            <div class="result-row">
                <span>Age</span>
                <span>@Model.Age</span>
            </div>

            <div class="result-row">
                <span>Gender</span>
                <span>@Model.Gender</span>
            </div>

            <div class="result-row">
                <span>BMI</span>
                <span>@Model.BMI.ToString("0.00")</span>
            </div>

            <div class="result-row">
                <span>Category</span>
                <span>@Model.Category</span>
            </div>

            <div class="result-row">
                <span>Goal</span>
                <span>@Model.Goal</span>
            </div>

            <div class="result-row">
                <span>BMR</span>
                <span>@Model.BMR.ToString("0") kcal/day</span>
            </div>

            <div class="result-row">
                <span>Recommended Calories</span>
                <span>@Model.DailyCalories.ToString("0") kcal/day</span>
            </div>

            <!-- ✅ Macros -->
            <div class="result-row">
                <span>Protein</span>
                <span>@Model.ProteinGrams.ToString("0") g/day</span>
            </div>

            <div class="result-row">
                <span>Carbs</span>
                <span>@Model.CarbsGrams.ToString("0") g/day</span>
            </div>

            <div class="result-row">
                <span>Fat</span>
                <span>@Model.FatGrams.ToString("0") g/day</span>
            </div>
        </div>

        <div class="buttons">
            <a asp-action="ExerciseTips"
               asp-route-category="@Model.Category"
               class="btn-ht">
                Exercise Tips
            </a>

            <a asp-action="FoodTips"
               asp-route-category="@Model.Category"
               class="btn-ht">
                Nutrition Tips
            </a>
        </div>

        <a class="back"
           asp-action="NutritionClinic"
           asp-controller="Patient">
            ← Back to Nutrition
        </a>
    </div>

</body>
</html>
