@using Microsoft.AspNetCore.Http
@using System
@using System.Collections.Generic
@using System.Linq
@using HelthTrack.Models

@{
    Layout = null;

    var appointments = ViewBag.Appointments as List<AppointmentRecord> ?? new List<AppointmentRecord>();
    var clinicKey = (ViewBag.ClinicName as string ?? "DiabetesClinic").Trim();
    var patientName = Context.Session.GetString("UserName") ?? "Patient";

    string backUrl = clinicKey switch
    {
        "DiabetesClinic" => "/Patient/DiabetesClinic",
        "NutritionClinic" => "/Patient/NutritionClinic",
        "GeneralCheckup" => "/Patient/GeneralCheckup",
        "HeartClinic" => "/Patient/HeartClinic",
        _ => "/Patient/Dashboard_P"
    };

    string clinicDisplay = clinicKey switch
    {
        "DiabetesClinic" => "Diabetes Clinic",
        "NutritionClinic" => "Nutrition Clinic",
        "GeneralCheckup" => "General Checkup",
        "HeartClinic" => "Heart Clinic",
        _ => clinicKey
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Appointments</title>

    <style>
        :root {
            --bg1: #f5f7fb;
            --bg2: #eef2ff;
            --card: #ffffff;
            --text: #1f2937;
            --muted: #6b7280;
            --border: #e5e7eb;
            --shadow: 0 10px 25px rgba(0,0,0,.08);
            --primary: #2563eb;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: "Segoe UI", system-ui, Arial, sans-serif;
            color: var(--text);
            background: linear-gradient(135deg,var(--bg1),var(--bg2));
            min-height: 100vh;
        }

        .topbar {
            position: sticky;
            top: 0;
            background: #ffffffcc;
            backdrop-filter: blur(8px);
            border-bottom: 1px solid var(--border);
        }

        .topbar-inner {
            max-width: 1100px;
            margin: auto;
            padding: 16px 22px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
        }

        .badge {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            background: linear-gradient(135deg,#60a5fa,#3b82f6);
            color: white;
        }

        .brand small {
            display: block;
            color: var(--muted);
            font-weight: 600;
        }

        .btn {
            border: 1px solid var(--border);
            background: white;
            padding: 10px 14px;
            border-radius: 10px;
            font-weight: 700;
            text-decoration: none;
            color: var(--text);
            cursor: pointer;
        }

            .btn:hover {
                background: #f3f4f6;
            }

        .btn-primary {
            background: var(--primary);
            color: white;
            border: none;
        }

        .wrap {
            max-width: 1100px;
            margin: 30px auto;
            padding: 0 22px 40px;
        }

        .header h1 {
            margin: 0;
            font-size: 26px;
        }

        .header p {
            margin: 6px 0 0;
            color: var(--muted);
            font-weight: 600;
        }

        .grid {
            display: grid;
            grid-template-columns: 1.2fr .8fr;
            gap: 18px;
            margin-top: 20px;
        }

        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .card-h {
            padding: 16px 18px;
            border-bottom: 1px solid var(--border);
            font-weight: 700;
            background: #f9fafb;
        }

        .card-b {
            padding: 16px 18px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 12px;
            border-bottom: 1px solid var(--border);
            text-align: left;
        }

        th {
            background: #f3f4f6;
            font-weight: 700;
        }

        .empty {
            padding: 14px;
            border: 1px dashed var(--border);
            border-radius: 12px;
            color: var(--muted);
            background: #fafafa;
        }

        input {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: 1px solid var(--border);
        }

            input:focus {
                outline: none;
                border-color: var(--primary);
            }

        .action-btn {
            padding: 6px 10px;
            border-radius: 8px;
            font-weight: 800;
            font-size: 13px;
            border: 1px solid var(--border);
            background: white;
            text-decoration: none;
            color: var(--text);
            display: inline-block;
            margin-right: 6px;
            cursor: pointer;
        }

            .action-btn:hover {
                background: #f3f4f6;
            }

        .action-danger {
            border-color: #fecaca;
            color: #b91c1c;
        }

        @@media (max-width:920px) {
            .grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <header class="topbar">
        <div class="topbar-inner">
            <div class="brand">
                <div class="badge">📅</div>
                <div>
                    Appointments
                    <small>@clinicDisplay • @patientName</small>
                </div>
            </div>

            <div style="display:flex; gap:10px;">
                <a class="btn" href="@backUrl">← Back</a>
                <a class="btn" href="/Account/Logout">Logout</a>
            </div>
        </div>
    </header>

    <main class="wrap">
        <div class="header">
            <h1>Your Appointments</h1>
            <p>Manage and track your clinic appointments.</p>
        </div>

        <section class="grid">
            <!-- List -->
            <div class="card">
                <div class="card-h">Upcoming Appointments</div>
                <div class="card-b">
                    @if (appointments.Any())
                    {
                        <table>
                            <thead>
                                <tr>
                                    <th style="width:240px;">Date</th>
                                    <th>Description</th>
                                    <th style="width:200px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in appointments)
                                {
                                    <tr>
                                        <td>@a.Date.ToString("ddd, dd MMM yyyy • HH:mm")</td>
                                        <td>@a.Description</td>
                                        <td>
                                            <a class="action-btn" href="/Patient/EditAppointment/@a.Id?from=@clinicKey">Edit</a>

                                            <form method="post" action="/Patient/DeleteAppointment" style="display:inline;"
                                                  onsubmit="return confirm('Delete this appointment?');">
                                                <input type="hidden" name="id" value="@a.Id" />
                                                <input type="hidden" name="from" value="@clinicKey" />
                                                <button type="submit" class="action-btn action-danger">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty">No appointments yet.</div>
                    }
                </div>
            </div>

            <!-- Add -->
            <div class="card">
                <div class="card-h">Add Appointment</div>
                <div class="card-b">
                    <form method="post" action="/Patient/AddAppointment" style="display:grid; gap:10px;">
                        <input type="hidden" name="from" value="@clinicKey" />

                        <input type="datetime-local" name="date" required />
                        <input type="text" name="description" placeholder="e.g. Sugar check, doctor visit" required />

                        <button class="btn btn-primary" type="submit">➕ Add</button>
                    </form>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
