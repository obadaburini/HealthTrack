@using Microsoft.AspNetCore.Http
@{
    Layout = null;
    var patientName = Context.Session.GetString("UserName") ?? "Patient";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Diabetes Clinic</title>

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #ff9a9e, #fad0c4);
            margin: 0;
            padding: 0;
            color: #333;
        }

        .top-bar {
            background: rgba(0,0,0,0.15);
            padding: 18px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 20px;
        }

        .logout {
            background: #ff4d4d;
            padding: 10px 18px;
            border-radius: 8px;
            text-decoration: none;
            color: white;
            font-weight: bold;
        }

        .container {
            padding: 40px;
            max-width: 900px;
            margin: auto;
        }

        h2 {
            color: #d32f2f;
            margin-bottom: 10px;
        }

        .card {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
            margin-bottom: 20px;
        }

        .btn {
            display: inline-block;
            background: #d32f2f;
            color: white;
            padding: 10px 16px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
            margin-top: 10px;
        }

            .btn:hover {
                background: #b71c1c;
            }

        .back {
            display: inline-block;
            margin-top: 30px;
            color: #d32f2f;
            font-weight: bold;
            text-decoration: none;
        }
    </style>
</head>

<body>

    <!-- 🔴 Top Bar -->
    <div class="top-bar">
        <div>🩸 Diabetes Clinic</div>
        <a href="/Account/Logout" class="logout">Logout</a>
    </div>

    <div class="container">
        <h2>Welcome, @patientName</h2>
        <p>This clinic helps you manage blood sugar and diabetes health.</p>

        <!-- Blood Sugar -->
        <div class="card">
            <h3>📊 Blood Sugar Tracking</h3>
            <p>Record and monitor your daily blood sugar levels.</p>
            <a class="btn" asp-controller="Patient" asp-action="BloodSugar">
                Add / View Blood Sugar
            </a>
        </div>

        <!-- Appointments -->
        <div class="card">
            <h3>📅 Appointments</h3>
            <p>Check your upcoming diabetes clinic appointments.</p>
            <a class="btn"
               asp-controller="Patient"
               asp-action="Appointments"
               asp-route-from="DiabetesClinic">
                View Appointments
            </a>
        </div>

        <!-- 🔙 Back to All Clinics -->
        <a class="back" href="/Patient/Dashboard_P">← Back to Clinics</a>
    </div>

</body>
</html>
