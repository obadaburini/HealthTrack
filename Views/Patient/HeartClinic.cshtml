@using Microsoft.AspNetCore.Http
@{
    Layout = null;
    var patientName = Context.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Heart Clinic</title>
    <style>
        body{font-family:'Segoe UI',sans-serif;background:linear-gradient(135deg,#ffecd2,#fcb69f);margin:0;color:#333;}
        .top-bar{background:rgba(0,0,0,0.15);padding:18px 25px;display:flex;justify-content:space-between;font-size:20px;}
        .logout{background:#ff4d4d;padding:10px 18px;border-radius:8px;text-decoration:none;color:white;font-weight:bold;}
        .container{padding:40px;max-width:900px;margin:auto;}
        h2{color:#b91c1c;margin-bottom:10px;}
        .card{background:white;padding:25px;border-radius:15px;box-shadow:0 5px 20px rgba(0,0,0,0.2);margin-bottom:20px;}
        .btn{display:inline-block;background:#b91c1c;color:white;padding:10px 16px;border-radius:8px;text-decoration:none;font-weight:bold;margin-top:10px;}
        .btn:hover{background:#7f1d1d;}
        .back{color:#b91c1c;font-weight:bold;text-decoration:none;}
    </style>
</head>
<body>
    <div class="top-bar">
        <div>❤️ Heart Clinic</div>
        <a href="/Account/Logout" class="logout">Logout</a>
    </div>

    <div class="container">
        <h2>Welcome, @patientName</h2>
        <p>Track your blood pressure and heart rate.</p>

        <div class="card">
            <h3>🩺 Blood Pressure & Heart Rate</h3>
            <p>Add readings and view classification + history.</p>
            <a class="btn" href="/Patient/HeartVitals">Open</a>
        </div>

        <div class="card">
            <h3>📅 Appointments</h3>
            <p>Manage heart clinic appointments.</p>
            <a class="btn" href="/Patient/Appointments?from=HeartClinic">View Appointments</a>
        </div>

        <a class="back" href="/Patient/Dashboard_P">← Back to Dashboard</a>
    </div>
</body>
</html>
