@model HelthTrack.Models.Patient

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Confirm Delete</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
        :root {
            --bg: #f8fafc;
            --card: #ffffff;
            --text: #0f172a;
            --muted: #64748b;
            --border: #e5e7eb;
            --danger: #ef4444;
            --radius: 14px;
            --shadow: 0 10px 25px rgba(0,0,0,.08);
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: var(--bg);
            font-family: 'Segoe UI', system-ui, Arial, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text);
        }

        .card {
            background: var(--card);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            width: 100%;
            max-width: 420px;
            padding: 22px;
        }

        h3 {
            margin: 0 0 10px;
            font-size: 20px;
            font-weight: 900;
        }

        p {
            margin: 0 0 18px;
            color: var(--muted);
            font-weight: 700;
            line-height: 1.6;
        }

        .info {
            background: #f8fafc;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 18px;
            font-size: 14px;
            font-weight: 700;
        }

            .info strong {
                color: var(--text);
            }

        .actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

        .btn {
            padding: 8px 16px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: #ffffff;
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
        }

        .btn-cancel {
            color: var(--text);
        }

        .btn-danger {
            background: var(--danger);
            color: #fff;
            border: none;
        }

            .btn-danger:hover {
                filter: brightness(1.05);
            }
    </style>
</head>

<body>

    <div class="card">
        <h3>Confirm Delete</h3>

        <p>
            Are you sure you want to remove this patient from your list?
            This action cannot be undone.
        </p>

        <div class="info">
            <div><strong>Name:</strong> @Model.PatientUser?.FullName</div>
            <div><strong>Username:</strong> @Model.PatientUser?.Username</div>
        </div>

        <form asp-controller="Doctor" asp-action="DeletePatient" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.PatientUserId" />

            <div class="actions">
                <a class="btn btn-cancel" asp-controller="Doctor" asp-action="Patients">
                    Cancel
                </a>

                <button type="submit" class="btn btn-danger">
                    Delete
                </button>
            </div>
        </form>
    </div>

</body>
</html>
